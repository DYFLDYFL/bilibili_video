# Copy to config.ps1 and edit as needed.

# $ShowConsole = $false
# $YtdlpPath = 'C:\path\to\yt-dlp.exe'

# Cookie：优先 runtime/bilibili-cookies.txt（点击时自动导出）
# 也可手动指定 Netscape 格式 cookies.txt（须含 SESSDATA）：
# $YtdlpCookiesFile = 'C:\path\to\bilibili.com.cookies.txt'
# $YtdlpCookieBrowser = 'edge'   # 本窗口 Cookie 导出失败时，可读系统 Edge 登录态

# 点播默认 format（登录后 yt-dlp 会自动选最高；也可写大会员优先链）：
# $DefaultVodFormat = 'bestvideo+bestaudio/best'
# $DefaultVodFormat = '100029+30280/100026+30280/bestvideo+bestaudio/best'

# 直播弹幕 overlay（需 Node.js；默认开启，见 Start-StreamPlay.ps1）
# $EnableLiveDanmaku = $true
# 弹幕滚动速度（px/tick @ 40ms；默认 10 ≈ 250px/s，越大越快）
# 10 约 3 秒横穿 800px 窗口，全屏 1920px 约需 8 秒
# $DanmakuSpeed = 10
# 弹幕出现频率（秒/条，0=不限制；比如 3 表示至少间隔 3 秒才显示下一条）
# $DanmakuRate = 0
